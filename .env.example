# =============================================================
# Sales Advisor — environment variables template
# Copy this file to .env.local (dev) or set on VPS (.env)
# =============================================================

# ----- Supabase (déjà configuré) -----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ----- OpenAI (déjà configuré) -----
OPENAI_API_KEY=

# ----- Google Maps JavaScript API -----
# Required for the "Zone de prospection" map on /prospect-finder
# 1. Get key: https://console.cloud.google.com/google/maps-apis/credentials
# 2. Restrict by HTTP referrer (your prod domain + http://localhost:*)
# 3. Enable APIs: Maps JavaScript API
# 4. Never commit the real key — only the placeholder name
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
